<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jd.wms.dao.mapper.UserMapper">

    <select id="selectByWorkNo" resultType="com.jd.wms.dao.entity.User">
        SELECT * FROM user WHERE work_no = #{workNo}
    </select>

    <select id="selectByPhone" resultType="com.jd.wms.dao.entity.User">
        SELECT * FROM user WHERE phone = #{phone}
    </select>

</mapper>